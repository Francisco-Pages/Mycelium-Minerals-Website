# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Create a project at sanity.io and copy the project ID from the API settings.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Read token for draft previews (optional until preview mode is implemented).
# Generate in Sanity: Manage → API → Tokens → Add API token (Viewer role).
SANITY_API_READ_TOKEN=

# Secret used to verify Sanity webhook calls to /api/revalidate.
# Generate any random string: openssl rand -hex 32
SANITY_REVALIDATE_SECRET=

# ─── Mapbox ───────────────────────────────────────────────────────────────────
# Create a free account at mapbox.com and copy a public (pk.*) access token.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── AWS SES (contact form) ───────────────────────────────────────────────────
# IAM user with ses:SendEmail permission in your AWS region.
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=noreply@myceliumminerals.com
SES_TO_EMAIL=ir@myceliumminerals.com

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
